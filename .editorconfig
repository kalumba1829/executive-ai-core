# .editorconfig
# ==============
# This file tells code editors how to format files consistently,
# regardless of which editor each contributor uses (VS Code, PyCharm, Vim, etc.)
# Most editors support this format natively or via a plugin.
# Learn more at : https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.yml]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
